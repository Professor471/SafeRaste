# SafeRaste Environment Variables
# Copy this file to .env and fill in your values

# Cognee Cloud API key (get free Developer plan with code COGNEE-35 at https://cloud.cognee.ai)
COGNEE_API_KEY=your_cognee_api_key_here

# LLM provider (OpenRouter recommended for free-tier access)
LLM_API_KEY=your_llm_api_key_here
